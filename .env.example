# RAG Investment Analysis - Environment Variables

# Embedding Model Configuration
# Options: simple (default, free), huggingface (free API), openai (paid), local (requires installation)
EMBEDDING_MODEL=simple

# LLM Model Configuration
# Options: simple (default, free), huggingface (free API), openai (paid)
LLM_MODEL=simple

# OpenAI API Key (only needed if using openai models)
# OPENAI_API_KEY=sk-your-key-here

# Hugging Face API Token (optional, improves rate limits)
# HUGGINGFACE_API_TOKEN=hf_your_token_here

# Vector Store Backend
# Options: chroma (default, local), firebase (cloud)
VECTOR_STORE_BACKEND=chroma

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# Production Settings
ENVIRONMENT=production
DEBUG=false

# Firebase Configuration (only if using firebase backend)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CREDENTIALS_PATH=/path/to/credentials.json
